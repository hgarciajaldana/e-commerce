{
  "permissions": {
    "allow": ["Bash(*)", "Read(*)", "Edit(*)", "Write(*)", "MultiEdit(*)", "WebFetch(*)", "WebSearch(*)", "TodoWrite", "TodoRead"],
    "deny": []
  },
  "defaultMode": "bypassPermissions",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ]
  }
}
