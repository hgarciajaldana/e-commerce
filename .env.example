# ============================================================================
# .env.example — Ecommerce Multi-Tenant
# Copia este archivo a .env y completa los valores
#   cp .env.example .env
#
# OBLIGATORIO: POSTGRES_PASSWORD debe tener un valor para que docker compose up funcione
# ============================================================================

# ── PostgreSQL (usado por docker-compose) ─────────────────────────────────────
POSTGRES_DB=proyecto_a
POSTGRES_USER=proyecto_a
POSTGRES_PASSWORD=            # ← OBLIGATORIO — pon tu contraseña aquí

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── URLs públicas (Cloudflare Tunnels o dominio propio) ───────────────────────
NEXT_PUBLIC_API_URL=https://api-ecommerce.operly.tech
NEXT_PUBLIC_APP_DOMAIN=ecommerce.operly.tech

# ── PgAdmin (opcional — docker compose --profile tools up -d) ─────────────────
PGADMIN_EMAIL=admin@ecomerce.dev
PGADMIN_PASSWORD=admin

# ── Notas de puertos ──────────────────────────────────────────────────────────
# postgres: expuesto en host:5435 (5432-5434 pueden estar en uso por otros proyectos)
# backend:  expuesto en host:4001 (mismo que el dev local)
# frontend: expuesto en host:4002 — requiere detener el dev server local si está corriendo
