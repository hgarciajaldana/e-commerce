# ============================================================
# Backend — Ecommerce Multi-Tenant
# Copiar a .env y completar los valores
# ============================================================

# Servidor
NODE_ENV=development
PORT=4001

# Base de datos (PostgreSQL 16)
DATABASE_URL=postgresql://user:password@localhost:5432/ecomerce

# JWT (HS256)
JWT_SECRET=cambiar_por_secreto_seguro_de_al_menos_32_caracteres
JWT_EXPIRES_IN=7d

# CORS — dominios permitidos (separados por coma)
# Ejemplo: http://localhost:3000,https://empresa.plataforma.com
ALLOWED_ORIGINS=http://localhost:4002,https://ecommerce.operly.tech

# File uploads
UPLOAD_MAX_SIZE_MB=5
UPLOADS_DIR=./uploads

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_STORE_MAX=120
RATE_LIMIT_ADMIN_MAX=60
RATE_LIMIT_CHECKOUT_MAX=10
